# ─── LM Studio ───────────────────────────────────────────────────────────────
# Windows native: use localhost
# WSL2:           use host.docker.internal (Docker Desktop auto-resolves this)
# WSL2 + Docker Engine (no Desktop): use your WSL2 host IP (run: ip route | grep default)
LM_STUDIO_URL=http://host.docker.internal:1234
LM_STUDIO_MODEL=qwen2.5-14b

# ─── Infrastructure ───────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379
DATABASE_URL=postgresql://agent:agent@postgres:5432/agentmem

# ─── Discord Bridge ───────────────────────────────────────────────────────────
# 1. Create a bot at https://discord.com/developers/applications
# 2. Under Bot → enable "Message Content Intent"
# 3. Invite the bot with scopes: bot + applications.commands
#    Permissions: Administrator (or at minimum: Manage Channels, Send Messages,
#                 Embed Links, Add Reactions, Read Message History, Manage Messages)
# 4. Right-click each channel → Copy Channel ID (enable Developer Mode first)
# 5. Right-click your server → Copy Server ID (= DISCORD_GUILD_ID)
#
# Channel layout (create these in Discord):
#   INPUT  : #general         — conversational tasks; agent reactions (⏳/✅/📓) appear here
#   INPUT  : #intake          — async backlog (bugs, features, reminders); reactions but no replies
#   INPUT  : #claude          — direct Claude chat + agent escalation requests
#   INPUT  : #control         — bot restart / status commands
#   OUTPUT : #logs            — plan status, verbose events, context closed
#   OUTPUT : #errors          — system errors, memory warnings
#   OUTPUT : #task-tracking   — task lifecycle (created / failed / completed)
#   OUTPUT : #votes           — agent deliberation, plan votes
#   OUTPUT : #approvals       — approval.required, vote escalations to user
DISCORD_BOT_TOKEN=your-bot-token-here
DISCORD_GUILD_ID=your-guild-id-here                  # Right-click server name → Copy Server ID
DISCORD_GENERAL_CHANNEL_ID=your-channel-id-here      # Required — #general
DISCORD_INTAKE_CHANNEL_ID=your-channel-id-here       # Optional — #intake
DISCORD_CLAUDE_CHANNEL_ID=your-channel-id-here       # Optional — #claude
DISCORD_CONTROL_CHANNEL_ID=your-channel-id-here      # Optional — #control
DISCORD_LOGS_CHANNEL_ID=your-channel-id-here         # Optional — #logs
DISCORD_ERRORS_CHANNEL_ID=your-channel-id-here       # Optional — #errors
DISCORD_TASK_TRACKING_CHANNEL_ID=your-channel-id-here # Optional — #task-tracking
DISCORD_VOTES_CHANNEL_ID=your-channel-id-here        # Optional — #votes
DISCORD_APPROVALS_CHANNEL_ID=your-channel-id-here    # Optional — #approvals
DISCORD_KNOWLEDGE_GAP_CHANNEL_ID=your-channel-id-here # Optional — #knowledge-gap

# ─── Host Restart Helper ──────────────────────────────────────────────────────
# The helper runs on the Windows host (scripts/start_host_helper.bat).
# Containers reach it via host.docker.internal:7799.
# Only change this if you run the helper on a different port.
CONTROL_HELPER_URL=http://host.docker.internal:7799
# LM_STUDIO_PATH=C:\Users\you\AppData\Local\Programs\lm-studio\LM Studio.exe

# ─── Hugging Face ────────────────────────────────────────────────────────────
# Optional but recommended — prevents rate limiting when downloading models
# Get a free token at https://huggingface.co/settings/tokens
HF_TOKEN=

# ─── Claude API ──────────────────────────────────────────────────────────────
# Required for the #claude channel / claude_code_agent service.
# Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6
# CLAUDE_MAX_TOKENS=8192

# ─── Document QA / Architecture Watcher ─────────────────────────────────────
# Minimum seconds between full LLM+LaTeX architecture builds (default: 86400 = 24 h).
# Minor changes between full builds are recorded in CHANGELOG.md with no agent spin-up.
# Set to a lower value (e.g. 3600) during initial setup to test the full pipeline.
ARCH_FULL_BUILD_INTERVAL=86400

# Google Drive sync (optional) — leave blank to disable.
# 1. Create a GCP project → enable "Google Drive API"
# 2. Create a Service Account → download JSON key → save as config/google_sa.json
# 3. Share your Drive folder with the service account email (Editor access)
# 4. Set GOOGLE_DRIVE_FOLDER_ID to the folder ID from the Drive URL
GOOGLE_DRIVE_FOLDER_ID=
# GOOGLE_APPLICATION_CREDENTIALS is auto-set to /run/secrets/google_sa.json inside the container.
# Place the service account JSON at: config/google_sa.json

# ─── Research Agent ───────────────────────────────────────────────────────────
# Brave Search API key — sign up at https://brave.com/search/api/
# Free tier: 2,000 queries/month. Leave blank to disable live web search
# (Wikipedia offline lookup will still work without a key).
BRAVE_API_KEY=

# Path to the Wikipedia offline dump inside the container (mounted from ./workspace/wiki).
# Requires both the multistream XML dump and the index file:
#   enwiki-*-pages-articles-multistream.xml.bz2
#   enwiki-*-pages-articles-multistream-index.txt.bz2
WIKI_DIR=/workspace/wiki

# MAX_SEARCH_ITERATIONS=3   # search → extract → gap-fill loops per research task
# MAX_RESULTS_PER_QUERY=8   # Brave hits per sub-query

# ─── Logging ──────────────────────────────────────────────────────────────────
# Options: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# ─── Version stamp ────────────────────────────────────────────────────────────
# Increment when deploying a new version. The orchestrator flushes stale
# learned-intent examples from memory when this value changes.
AGENT_VERSION=1.0
