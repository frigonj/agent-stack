# ─── LM Studio ───────────────────────────────────────────────────────────────
# Windows native: use localhost
# WSL2:           use host.docker.internal (Docker Desktop auto-resolves this)
# WSL2 + Docker Engine (no Desktop): use your WSL2 host IP (run: ip route | grep default)
LM_STUDIO_URL=http://host.docker.internal:1234
LM_STUDIO_MODEL=qwen2.5-14b

# ─── Infrastructure ───────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379
DATABASE_URL=postgresql://agent:agent@postgres:5432/agentmem

# ─── Discord Bridge ───────────────────────────────────────────────────────────
# 1. Create a bot at https://discord.com/developers/applications
# 2. Under Bot → enable "Message Content Intent"
# 3. Invite the bot with scopes: bot + applications.commands
#    Permissions: Administrator (or at minimum: Manage Channels, Send Messages,
#                 Embed Links, Add Reactions, Read Message History, Manage Messages)
# 4. Right-click your #agent-tasks channel → Copy Channel ID (enable Developer Mode first)
# 5. Right-click your server → Copy Server ID (= DISCORD_GUILD_ID)
DISCORD_BOT_TOKEN=your-bot-token-here
DISCORD_TASK_CHANNEL_ID=your-channel-id-here
DISCORD_GUILD_ID=your-guild-id-here              # Right-click server name → Copy Server ID
DISCORD_CLAUDE_CHANNEL_ID=your-claude-channel-id   # Optional — #claude → Claude API agent
DISCORD_CONTROL_CHANNEL_ID=your-control-channel-id # Optional — #control → restart commands
DISCORD_LOG_CHANNEL_ID=your-log-channel-id         # Optional — #agent-logs → verbose process tracking
DISCORD_VOTE_CHANNEL_ID=your-vote-channel-id       # Optional — #agent-deliberation → plan votes

# ─── Host Restart Helper ──────────────────────────────────────────────────────
# The helper runs on the Windows host (scripts/start_host_helper.bat).
# Containers reach it via host.docker.internal:7799.
# Only change this if you run the helper on a different port.
CONTROL_HELPER_URL=http://host.docker.internal:7799
# LM_STUDIO_PATH=C:\Users\you\AppData\Local\Programs\lm-studio\LM Studio.exe

# ─── Hugging Face ────────────────────────────────────────────────────────────
# Optional but recommended — prevents rate limiting when downloading models
# Get a free token at https://huggingface.co/settings/tokens
HF_TOKEN=

# ─── Claude API ──────────────────────────────────────────────────────────────
# Required for the #claude channel / claude_code_agent service.
# Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6
# CLAUDE_MAX_TOKENS=8192

# ─── Document QA / Architecture Watcher ─────────────────────────────────────
# Minimum seconds between full LLM+LaTeX architecture builds (default: 86400 = 24 h).
# Minor changes between full builds are recorded in CHANGELOG.md with no agent spin-up.
# Set to a lower value (e.g. 3600) during initial setup to test the full pipeline.
ARCH_FULL_BUILD_INTERVAL=86400

# Google Drive sync (optional) — leave blank to disable.
# 1. Create a GCP project → enable "Google Drive API"
# 2. Create a Service Account → download JSON key → save as config/google_sa.json
# 3. Share your Drive folder with the service account email (Editor access)
# 4. Set GOOGLE_DRIVE_FOLDER_ID to the folder ID from the Drive URL
GOOGLE_DRIVE_FOLDER_ID=
# GOOGLE_APPLICATION_CREDENTIALS is auto-set to /run/secrets/google_sa.json inside the container.
# Place the service account JSON at: config/google_sa.json

# ─── Research Agent / SearXNG ────────────────────────────────────────────────
# Self-hosted meta-search engine (Google + Bing + DDG aggregated, no API key needed).
# Inside Docker: http://searxng:8080  |  From host browser: http://localhost:8080
SEARXNG_URL=http://searxng:8080
# SEARXNG_SECRET_KEY=changeme-replace-in-prod
# MAX_SEARCH_ITERATIONS=3   # search → extract → gap-fill loops per research task
# MAX_RESULTS_PER_QUERY=8   # SearXNG hits per sub-query

# ─── Logging ──────────────────────────────────────────────────────────────────
# Options: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
